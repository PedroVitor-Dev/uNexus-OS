#!/usr/bin/env sh
set -eu

log() {
    printf '[uNexus session] %s\n' "$*"
}

find_terminal() {
    for terminal in foot kitty alacritty wezterm konsole gnome-terminal xterm; do
        if command -v "$terminal" >/dev/null 2>&1; then
            printf '%s\n' "$terminal"
            return 0
        fi
    done

    return 1
}

if ! command -v Hyprland >/dev/null 2>&1; then
    log "Hyprland was not found in PATH."
    exit 1
fi

export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
export XDG_SESSION_DESKTOP="${XDG_SESSION_DESKTOP:-uNexus}"
export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-uNexus:Hyprland}"
export DESKTOP_SESSION="${DESKTOP_SESSION:-uNexus}"
export GDK_BACKEND="${GDK_BACKEND:-wayland,x11}"
export QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-wayland;xcb}"
export QT_QUICK_CONTROLS_STYLE="${QT_QUICK_CONTROLS_STYLE:-Fusion}"
export GTK_THEME="${GTK_THEME:-Adwaita:dark}"
export XCURSOR_THEME="${XCURSOR_THEME:-Adwaita}"
export XCURSOR_SIZE="${XCURSOR_SIZE:-24}"
export SDL_VIDEODRIVER="${SDL_VIDEODRIVER:-wayland}"
export CLUTTER_BACKEND="${CLUTTER_BACKEND:-wayland}"

browser_command=""
browser_desktop=""
if command -v brave-browser >/dev/null 2>&1; then
    browser_command="brave-browser"
    browser_desktop="brave-browser.desktop"
elif command -v brave >/dev/null 2>&1; then
    browser_command="brave"
    browser_desktop="brave-browser.desktop"
elif command -v flatpak >/dev/null 2>&1 && flatpak info com.brave.Browser >/dev/null 2>&1; then
    browser_command="flatpak run com.brave.Browser"
    browser_desktop="com.brave.Browser.desktop"
fi

if [ -n "$browser_command" ]; then
    export BROWSER="${BROWSER:-$browser_command}"
fi

runtime_root="${XDG_RUNTIME_DIR:-/tmp}/unexus"
state_root="${XDG_STATE_HOME:-$HOME/.local/state}/unexus"
log_root="$state_root/logs"
session_config="$runtime_root/hyprland.conf"
session_log="$log_root/session.log"
user_config="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/hyprland.conf"
fallback_terminal="$(find_terminal || true)"
polkit_agent="/usr/lib/polkit-kde-authentication-agent-1"

mkdir -p "$runtime_root"
mkdir -p "$log_root"

{
    echo "# Generated by unexus-session."
    echo "# User config is loaded first when present, then uNexus starts once."
    echo "env = XDG_SESSION_TYPE,wayland"
    echo "env = XDG_SESSION_DESKTOP,uNexus"
    echo "env = XDG_CURRENT_DESKTOP,uNexus:Hyprland"
    echo "env = DESKTOP_SESSION,uNexus"
    echo "env = GDK_BACKEND,wayland,x11"
    echo "env = QT_QPA_PLATFORM,wayland;xcb"
    echo "env = QT_QUICK_CONTROLS_STYLE,Fusion"
    echo "env = GTK_THEME,Adwaita:dark"
    echo "env = XCURSOR_THEME,Adwaita"
    echo "env = XCURSOR_SIZE,24"
    echo "env = SDL_VIDEODRIVER,wayland"
    echo "env = CLUTTER_BACKEND,wayland"
    if [ -n "${BROWSER:-}" ]; then
        printf 'env = BROWSER,%s\n' "$BROWSER"
    fi
    if [ -f "$user_config" ]; then
        printf 'source = %s\n' "$user_config"
    fi

    echo "exec-once = sh -lc 'mkdir -p \"\${XDG_CONFIG_HOME:-\$HOME/.config}/gtk-3.0\" \"\${XDG_CONFIG_HOME:-\$HOME/.config}/gtk-4.0\"; for gtk_dir in \"\${XDG_CONFIG_HOME:-\$HOME/.config}/gtk-3.0\" \"\${XDG_CONFIG_HOME:-\$HOME/.config}/gtk-4.0\"; do printf \"[Settings]\\ngtk-theme-name=Adwaita\\ngtk-icon-theme-name=Papirus-Dark\\ngtk-cursor-theme-name=Adwaita\\ngtk-application-prefer-dark-theme=1\\n\" > \"\$gtk_dir/settings.ini\"; done; if command -v xdg-icon-resource >/dev/null 2>&1; then xdg-icon-resource forceupdate || true; fi; if command -v update-mime-database >/dev/null 2>&1; then update-mime-database \"\${XDG_DATA_HOME:-\$HOME/.local/share}/mime\" >/dev/null 2>&1 || true; fi'"

    echo "bind = SUPER, S, exec, unexus-shell --shortcut launcher"
    echo "bind = SUPER, SPACE, exec, unexus-shell --shortcut launcher"
    echo "bind = SUPER, I, exec, unexus-shell --shortcut settings"
    echo "bind = SUPER, G, exec, unexus-shell --shortcut stats"
    echo "bind = SUPER ALT, G, exec, unexus-shell --shortcut gameSettings"
    if [ -n "$browser_desktop" ]; then
        printf "exec-once = sh -lc 'if command -v xdg-settings >/dev/null 2>&1; then env -u BROWSER xdg-settings set default-web-browser %s; fi; if command -v xdg-mime >/dev/null 2>&1; then xdg-mime default %s x-scheme-handler/http x-scheme-handler/https text/html application/xhtml+xml; fi'\n" "$browser_desktop" "$browser_desktop"
    fi
    if [ -x "$polkit_agent" ]; then
        printf 'exec-once = %s\n' "$polkit_agent"
    fi
    if command -v unexus-shell >/dev/null 2>&1; then
        printf "exec-once = sh -lc 'unexus-shell >>\"%s\" 2>&1 || %s'\n" "$session_log" "${fallback_terminal:-true}"
    elif [ -n "$fallback_terminal" ]; then
        printf 'exec-once = %s\n' "$fallback_terminal"
    fi
} > "$session_config"

if ! command -v unexus-shell >/dev/null 2>&1; then
    log "unexus-shell was not found. Starting Hyprland with fallback terminal only."
fi

exec Hyprland -c "$session_config"
