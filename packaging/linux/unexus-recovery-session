#!/usr/bin/env sh
set -eu

find_terminal() {
    for terminal in foot kitty alacritty wezterm konsole gnome-terminal xterm; do
        if command -v "$terminal" >/dev/null 2>&1; then
            printf '%s\n' "$terminal"
            return 0
        fi
    done

    return 1
}

if ! command -v Hyprland >/dev/null 2>&1; then
    echo "[uNexus recovery] Hyprland was not found in PATH." >&2
    exit 1
fi

terminal="$(find_terminal || true)"
if [ -z "$terminal" ]; then
    echo "[uNexus recovery] No supported terminal was found." >&2
    exit 1
fi

runtime_root="${XDG_RUNTIME_DIR:-/tmp}/unexus"
session_config="$runtime_root/recovery-hyprland.conf"
mkdir -p "$runtime_root"

{
    echo "# Generated by unexus-recovery-session."
    echo "monitor=,preferred,auto,1"
    echo "exec-once = $terminal"
    echo "bind = SUPER, RETURN, exec, $terminal"
    echo "bind = SUPER, Q, killactive"
    echo "bind = SUPER, M, exit"
} > "$session_config"

exec Hyprland -c "$session_config"
